# --- KiCad Project Files ---
# Temporary and backup files generated by the editors
*.bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.kicad_prl
*-save.kicad_pcb
*-save.kicad_sch
*-backups/
*-cache.lib
*autosave*
*.lck

# Local settings and workspace data (specific to your machine/setup)
fp-info-cache
*.kicad_user_rev
/fp-lib-table
/sym-lib-table

# --- Output and Manufacturing Files ---
# These are usually generated from the source and shouldn't be versioned
/plots/
/gerbers/
/bom/
/drills/
/position/
*.gbr
*.drl
*.csv
*.pdf

# --- 3D and Simulation ---
# 3D model paths can be huge; better to manage via environment variables
/3d/
*.step
*.stp
*.wrl

# Simulation results
*.raw
*.plt
